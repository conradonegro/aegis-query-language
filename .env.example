# =============================================================================
# Aegis — environment configuration
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# HMAC secret used to sign and verify API keys.
# Generate a value with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY_HMAC_SECRET=

# Deployment environment. Controls security guards (e.g. blocks env-based
# secrets in production). Values: development | production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# DATABASE CONNECTION URLs
# Each role has least-privilege access. All four default to DATABASE_URL if
# the role-specific URL is not set (useful for local dev with a single DB user).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/aegis_data_warehouse

# Role-specific URLs (override DATABASE_URL in staging/production)
# DB_URL_RUNTIME=postgresql+asyncpg://user_aegis_runtime:runtime_pass@localhost:5432/aegis_data_warehouse
# DB_URL_REGISTRY_RUNTIME=postgresql+asyncpg://user_aegis_registry_runtime:registry_pass@localhost:5432/aegis_data_warehouse
# DB_URL_STEWARD=postgresql+asyncpg://user_aegis_steward:steward_pass@localhost:5432/aegis_data_warehouse
# DB_URL_REGISTRY_ADMIN=postgresql+asyncpg://user_aegis_registry_admin:admin_pass@localhost:5432/aegis_data_warehouse

# -----------------------------------------------------------------------------
# DATABASE PASSWORDS  (used by EnvFallbackProvider when SECRETS_PROVIDER=env)
# These are the passwords for each least-privilege PostgreSQL role.
# Only required if using role-specific DB URLs above.
# -----------------------------------------------------------------------------
# DB_PASS_RUNTIME=runtime_pass
# DB_PASS_REGISTRY_RUNTIME=registry_pass
# DB_PASS_STEWARD=steward_pass
# DB_PASS_REGISTRY_ADMIN=admin_pass
# DB_PASS_DATA_OWNER=data_owner_pass
# DB_PASS_META_OWNER=meta_owner_pass

# -----------------------------------------------------------------------------
# SECRETS PROVIDER  (default: env)
# env   — reads secrets from environment variables (dev only, blocked in prod)
# vault — reads secrets from HashiCorp Vault via AppRole auth
# -----------------------------------------------------------------------------
SECRETS_PROVIDER=env

# HMAC signing key for API key issuance (env provider only).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# SIGNING_KEY_DEV=aegis_dev_hmac_secret_key_001
# SIGNING_KEY_ID_DEV=dev-key-1

# HashiCorp Vault (only required when SECRETS_PROVIDER=vault)
# VAULT_ADDR=https://vault.example.com
# VAULT_APPROLE_ROLE_ID=
# VAULT_APPROLE_SECRET_ID=

# -----------------------------------------------------------------------------
# LLM PROVIDER  (default: mock)
# The mock provider is sufficient for infrastructure testing — it generates
# syntactically valid SQL from the filtered schema context without an API key.
# Set one of the options below to use a real model.
# -----------------------------------------------------------------------------
LLM_PROVIDER=mock

# Anthropic
# LLM_PROVIDER=anthropic:claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# LLM_PROVIDER=openai:gpt-4o
# OPENAI_API_KEY=sk-...

# Google
# LLM_PROVIDER=google:gemini-pro
# GOOGLE_API_KEY=...

# xAI
# LLM_PROVIDER=xai:grok-1
# XAI_API_KEY=...

# Ollama (local — also start with: docker compose --profile local-llm up)
# LLM_PROVIDER=ollama:llama3
# OLLAMA_URL=http://localhost:11434

# Comma-separated allowlist of provider slugs. Empty = all providers allowed.
# ALLOWED_LLM_PROVIDERS=anthropic,openai

# -----------------------------------------------------------------------------
# LLM RETRY  (default: 3 retries, 2s base delay)
# On HTTP 429 rate-limit responses, the gateway retries with exponential
# backoff and jitter. Retry-After header is respected when present.
# -----------------------------------------------------------------------------
# LLM_RETRY_COUNT=3
# LLM_RETRY_BASE_DELAY=2.0

# -----------------------------------------------------------------------------
# REDIS  (optional — enables session continuity across restarts)
# If not set, sessions are stored in-process and lost on restart.
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# SESSION_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# QUERY EXECUTION TUNING
# -----------------------------------------------------------------------------
# Maximum execution time per query in milliseconds (default: 5000).
# STATEMENT_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Enable schema hints injection via the /api/v1/query/execute endpoint.
# SCHEMA_HINTS=on

# Fail closed on ambiguous or no-match RAG results instead of proceeding
# without hints (default: off).
# RAG_STRICT_MODE=true

# -----------------------------------------------------------------------------
# BIRD DATASET  (optional, only needed with docker-compose.bird.yml)
# Path to the downloaded 01_BIRD_dev.sql file.
# Defaults to ./docker/bird_data/01_BIRD_dev.sql if not set.
# Download: https://drive.google.com/file/d/13VLWIwpw5E3d5DUkMvzw7hvHE67a4XkG/view?usp=sharing
# -----------------------------------------------------------------------------
# BIRD_SQL_PATH=./docker/bird_data/01_BIRD_dev.sql
